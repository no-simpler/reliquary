#!/usr/bin/env bash
#
# up — system-wide updater (brew/apt/…, npm, rust, zinit, vim-plug, gcloud,
# tmux/TPM, in-house relics).
#
# Resilience model:
#   * No `set -e`: each updater is isolated, so one failure never aborts the
#     rest of the run. Per-step status is collected and printed as a summary.
#   * Flaky / VPN-throttled networks are tolerated — git transfers abort instead
#     of hanging forever, package managers retry transient failures, and (when a
#     `timeout` binary is present) every network step has a hard wall-clock cap.
#   * Failures are surfaced loudly at the end instead of being swallowed.
#
# Flags / env:
#   --no-relics, UP_SKIP_RELICS=1     skip in-house relic updates
#   --no-decruft, UP_SKIP_DECRUFT=1   skip the OS-cruft sweep (decruft)
#   GIT_HTTP_LOW_SPEED_LIMIT/TIME     override the git stall thresholds (below)

set -o pipefail

# --- Colors ----------------------------------------------------------------
BOLD="\033[1m"; DIM="\033[2m"; RED="\033[31m"; GREEN="\033[32m"; YELLOW="\033[33m"; RESET="\033[0m"

print_msg()  { printf '%b\n' "${BOLD}==>${RESET} ${BOLD}${GREEN}$1${RESET}"; }
print_warn() { printf '%b\n' "${BOLD}${YELLOW}==>${RESET} ${YELLOW}$1${RESET}"; }
print_err()  { printf '%b\n' "${BOLD}${RED}!!>${RESET} ${RED}$1${RESET}"; }

# --- Network resilience (VPN-friendly) -------------------------------------
# Abort git transfers that stall under ~1 KB/s for 30s rather than hang forever
# on a flaky VPN. Covers brew taps, zinit, vim-plug, TPM and relic git fetches.
export GIT_HTTP_LOW_SPEED_LIMIT="${GIT_HTTP_LOW_SPEED_LIMIT:-1000}"
export GIT_HTTP_LOW_SPEED_TIME="${GIT_HTTP_LOW_SPEED_TIME:-30}"
# Bound SSH-based git (git@github …) connection setup and notice dead links.
export GIT_SSH_COMMAND="${GIT_SSH_COMMAND:-ssh -o ConnectTimeout=15 -o ServerAliveInterval=10 -o ServerAliveCountMax=3}"
# Homebrew + cargo: retry transient download failures (the exact class of error
# crates.io throws over a flaky VPN). cargo uses the git CLI so it also inherits
# the limits above.
export HOMEBREW_CURL_RETRIES="${HOMEBREW_CURL_RETRIES:-3}"
export CARGO_NET_RETRY="${CARGO_NET_RETRY:-3}"
export CARGO_NET_GIT_FETCH_WITH_CLI="${CARGO_NET_GIT_FETCH_WITH_CLI:-true}"

# --- Timeout shim ----------------------------------------------------------
# Hard wall-clock caps for network steps when a timeout binary is available
# (`timeout` on Linux, `gtimeout` from `brew install coreutils`). Without one,
# net_timeout runs the command directly and relies on the per-tool limits above.
if   command -v timeout  &>/dev/null; then TIMEOUT_BIN="timeout"
elif command -v gtimeout &>/dev/null; then TIMEOUT_BIN="gtimeout"
else TIMEOUT_BIN=""; fi

# net_timeout <seconds> <cmd...>
net_timeout() {
    local secs="$1"; shift
    if [ -n "$TIMEOUT_BIN" ]; then
        # --foreground keeps the child attached to the tty (sudo prompts, the
        # vim-plug UI) and lets Ctrl-C through.
        "$TIMEOUT_BIN" --foreground "$secs" "$@"
    else
        "$@"
    fi
}

# --- DNS priming -----------------------------------------------------------
# Best-effort: warm the system DNS cache for the given hosts so a tool with a
# flaky resolver (cargo/reqwest under this VPN's split-DNS times out resolving
# index.crates.io even while curl resolves it in milliseconds) gets a cached
# answer instead of a lookup timeout. Never fails the caller.
prime_dns() {
    local h
    for h in "$@"; do
        if command -v dscacheutil &>/dev/null; then
            dscacheutil -q host -a name "$h" >/dev/null 2>&1 || true
        elif command -v getent &>/dev/null; then
            getent hosts "$h" >/dev/null 2>&1 || true
        fi
    done
}

# net_looks_unreachable <file> — true if <file> contains a transient
# network/DNS error signature (vs a real build/tooling failure).
net_looks_unreachable() {
    grep -qiE 'dns error|request timed out|could not (GET|connect)|error sending request|failed to (get|download|fetch)|temporary failure in name resolution|connection (refused|reset|timed out)|network is unreachable' "$1"
}

# --- Step runner + summary -------------------------------------------------
# Convention: each update_* function returns 0 = ok, 3 = skipped, else = failed.
STEP_RESULTS=()

run_step() {
    # run_step <label> <function> [args...]
    local label="$1"; shift
    print_msg "${label}..."
    local rc=0
    "$@" || rc=$?
    case "$rc" in
        0) STEP_RESULTS+=("OK|${label}") ;;
        3) STEP_RESULTS+=("SKIP|${label}") ;;
        *) STEP_RESULTS+=("FAIL|${label} (exit ${rc})")
           print_err "${label} failed (exit ${rc}); continuing with remaining steps." ;;
    esac
    return 0
}

print_summary() {
    echo
    print_msg "Update summary"
    local entry status text
    local failures=0
    for entry in "${STEP_RESULTS[@]}"; do
        status="${entry%%|*}"
        text="${entry#*|}"
        case "$status" in
            OK)   printf '%b\n' "    ${GREEN}\xe2\x9c\x94 ${text}${RESET}" ;;
            SKIP) printf '%b\n' "    ${DIM}\xe2\x80\x93 ${text} (skipped)${RESET}" ;;
            *)    printf '%b\n' "    ${RED}\xe2\x9c\x97 ${text}${RESET}"; failures=$((failures + 1)) ;;
        esac
    done
    return "$failures"
}

# --- Package managers ------------------------------------------------------
update_brew() {
    local rc=0
    net_timeout 1200 brew update        || rc=1
    net_timeout 1800 brew upgrade        || rc=1
    net_timeout 1800 brew upgrade --cask || rc=1
    brew cleanup    || true
    brew doctor     || true   # advisory only — never fail the step on this
    return "$rc"
}

update_debian() {
    local rc=0
    sudo apt update          || rc=1
    sudo apt upgrade -y      || rc=1
    sudo apt dist-upgrade -y || rc=1
    sudo apt autoremove -y   || rc=1
    return "$rc"
}

update_redhat() {
    local rc=0
    sudo dnf upgrade -y    || rc=1
    sudo dnf autoremove -y || rc=1
    return "$rc"
}

update_arch() {
    local rc=0
    sudo pacman -Syu --noconfirm || rc=1
    sudo pacman -Sc --noconfirm  || rc=1
    return "$rc"
}

update_suse() {
    local rc=0
    sudo zypper refresh        || rc=1
    sudo zypper update -y      || rc=1
    sudo zypper dist-upgrade -y|| rc=1
    sudo zypper clean --all    || rc=1
    return "$rc"
}

# --- Global npm packages ---------------------------------------------------
update_npm() {
    command -v npm &>/dev/null || { echo "npm is not installed. Skipping."; return 3; }
    net_timeout 600 npm update -g --fetch-retries=3
}

# --- Rust toolchains -------------------------------------------------------
update_rust() {
    command -v rustup &>/dev/null || { echo "rustup is not installed. Skipping."; return 3; }
    net_timeout 600 rustup update
}

# Run `cargo install-update -a`, capturing a transcript (for network-vs-real
# classification) and cargo's true exit code in <rc_file>.
#
# When attached to a real terminal we run it under a pseudo-tty via script(1)
# so cargo keeps its colored, live progress output (and the red miette error
# box). Without a tty (piped, cron, background) script(1) can't allocate a pty,
# so we use a plain pipe — no color, but cargo still runs and is captured. As a
# safety net, if script(1) leaves an empty transcript (it failed to set up the
# pty and thus never ran cargo) we fall back to the pipe so the update still
# happens.
#   run_cargo_update <transcript_file> <rc_file>
run_cargo_update() {
    local log="$1" rcf="$2"
    local inner='cargo install-update -a; echo $? > "'"$rcf"'"'
    if [ -t 1 ] && [ -t 0 ] && command -v script &>/dev/null; then
        case "$OSTYPE" in
            darwin*|*bsd*) net_timeout 2400 script -q "$log" /bin/bash -c "$inner" ;;
            *)             net_timeout 2400 script -q -e -c "$inner" "$log" ;;
        esac
        [ -s "$log" ] && return 0   # pty worked; rc already stashed by $inner
    fi
    net_timeout 2400 cargo install-update -a 2>&1 | tee "$log"
    echo "${PIPESTATUS[0]}" > "$rcf"
}

# --- Cargo-installed binaries ----------------------------------------------
update_cargo_bins() {
    command -v cargo-install-update &>/dev/null || { echo "cargo-update is not installed. Skipping."; return 3; }

    local log rcf attempt=1 max=3 backoff=5 rc=0
    log="$(mktemp -t up-cargo 2>/dev/null || mktemp 2>/dev/null || echo "${TMPDIR:-/tmp}/up-cargo.$$")"
    rcf="$(mktemp -t up-cargo-rc 2>/dev/null || mktemp 2>/dev/null || echo "${TMPDIR:-/tmp}/up-cargo-rc.$$")"

    while :; do
        # crates.io throws transient DNS/timeout errors over this VPN; warming
        # the resolver cache first and spacing out a few retries rides out a
        # blip far better than cargo's own sub-second internal retries.
        prime_dns index.crates.io static.crates.io
        printf '1\n' > "$rcf"   # default to failure if the run is interrupted
        # Single, *visible* pass (check + update) under a tty for full color.
        # The old code ran `-l` (list) then a silent `-q` update, so the slow
        # part produced no output and looked hung.
        run_cargo_update "$log" "$rcf"
        rc="$(head -n1 "$rcf" 2>/dev/null)"; case "$rc" in ''|*[!0-9]*) rc=1 ;; esac
        [ "$rc" -eq 0 ] && break
        [ "$attempt" -ge "$max" ] && break
        print_warn "cargo update attempt ${attempt}/${max} failed (exit ${rc}); retrying in ${backoff}s..."
        sleep "$backoff"
        attempt=$((attempt + 1)); backoff=$((backoff * 2))
    done

    if [ "$rc" -ne 0 ] && net_looks_unreachable "$log"; then
        # Environmental (VPN/network), not a defect — report as skipped so it
        # doesn't flag the run red. The binaries get another shot next run.
        print_warn "crates.io looks unreachable (likely VPN/network) — leaving cargo binaries for next run."
        rc=3
    fi
    rm -f "$log" "$rcf"
    return "$rc"
}

# --- zinit + plugins -------------------------------------------------------
update_zinit() {
    command -v zsh &>/dev/null || return 3
    local ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
    [ -d "$ZINIT_HOME" ] || { echo "zinit is not installed. Skipping."; return 3; }

    local rc=0
    net_timeout 900 zsh -c "source '$ZINIT_HOME/zinit.zsh'; zinit self-update; zinit update --all" || rc=1

    # Clean up broken completion symlinks left by removed upstream completions.
    local completions_dir="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/completions"
    if [ -d "$completions_dir" ]; then
        find "$completions_dir" -type l ! -exec test -e {} \; -delete
    fi
    return "$rc"
}

# --- vim-plug plugins ------------------------------------------------------
update_vimplug() {
    command -v vim &>/dev/null || return 3
    [ -f "$HOME/.config/vim/autoload/plug.vim" ] || { echo "vim-plug is not installed. Skipping."; return 3; }
    # PlugUpdate clones/pulls over git, so it inherits the low-speed abort above.
    net_timeout 900 vim +PlugUpdate +qall
}

# --- gcloud CLI components -------------------------------------------------
update_gcloud() {
    command -v gcloud &>/dev/null || { echo "gcloud is not installed. Skipping."; return 3; }
    if ! net_timeout 30 gcloud info --format='value(config.account)' &>/dev/null; then
        echo "gcloud is not authenticated (or unreachable). Skipping."
        return 3
    fi
    net_timeout 900 gcloud components update --quiet
}

# --- tmux plugin manager ---------------------------------------------------
update_tpm() {
    local tpm_path="$HOME/.tmux/plugins/tpm"
    [ -d "$tpm_path" ] || { echo "TPM is not installed. Skipping."; return 3; }
    # --ff-only so a diverged local checkout can't hang on an interactive merge.
    net_timeout 300 git -C "$tpm_path" pull --ff-only
}

# --- In-house relics (~/.config/relics + ~/.config/attic) ------------------
# Opt out with UP_SKIP_RELICS=1 up  or  up --no-relics.
# Contract on each relic's scripts/update.sh: non-interactive, time-bounded.
update_relics() {
    if [ -n "${UP_SKIP_RELICS:-}" ]; then
        echo "Skipping relic update (UP_SKIP_RELICS set)."
        return 3
    fi
    case " $* " in
        *" --no-relics "*) echo "Skipping relic update (--no-relics)."; return 3 ;;
    esac

    local lib="$HOME/.config/reliquary/lib/relic.sh"
    [ -f "$lib" ] || return 3

    # shellcheck disable=SC1090
    source "$lib"

    local lane r rc=0
    for lane in "$HOME/.config/relics" "$HOME/.config/attic"; do
        [ -d "$lane" ] || continue
        for r in "$lane"/*/; do
            [ -f "${r}relic.sh" ] || continue
            ( cd "$r" && relic::update "$r" ) || { print_err "  relic update failed: $r"; rc=1; }
        done
    done
    return "$rc"
}

# --- OS cruft sweep (decruft) ----------------------------------------------
# Remove inert OS metadata cruft (.DS_Store, ._*, …) left in browsable git repos
# and the XDG depots — the local-disk counterpart to the macOS net/USB defaults
# (no OS toggle exists for internal volumes). Opt out with UP_SKIP_DECRUFT=1 or
# up --no-decruft.
update_decruft() {
    if [ -n "${UP_SKIP_DECRUFT:-}" ]; then
        echo "Skipping OS-cruft sweep (UP_SKIP_DECRUFT set)."
        return 3
    fi
    case " $* " in
        *" --no-decruft "*) echo "Skipping OS-cruft sweep (--no-decruft)."; return 3 ;;
    esac
    command -v decruft &>/dev/null || { echo "decruft is not installed. Skipping."; return 3; }
    decruft
}

# --- Main ------------------------------------------------------------------
print_msg "Updating system"

# Detect the OS and run the appropriate package-manager step.
if [[ "$OSTYPE" == "darwin"* ]]; then
    run_step "Homebrew" update_brew
elif [ -f /etc/debian_version ]; then
    run_step "APT packages" update_debian
elif [ -f /etc/redhat-release ]; then
    run_step "DNF packages" update_redhat
elif [ -f /etc/arch-release ]; then
    run_step "Pacman packages" update_arch
elif [ -f /etc/SuSE-release ]; then
    run_step "Zypper packages" update_suse
else
    print_warn "Unsupported OS — skipping system package update."
    STEP_RESULTS+=("SKIP|System packages (unsupported OS)")
fi

run_step "Global npm packages"            update_npm
run_step "Rust toolchains"                update_rust
run_step "Cargo binaries"                 update_cargo_bins
run_step "zinit & plugins"                update_zinit
run_step "vim-plug plugins"               update_vimplug
run_step "gcloud components"              update_gcloud
run_step "TPM"                            update_tpm
run_step "In-house relics"                update_relics "$@"
run_step "OS cruft sweep"                 update_decruft "$@"

# Record the attempt timestamp (marks "last ran up", regardless of per-step
# results — the interactive nag in shell/interactive.d/080-check.sh reads this).
mkdir -p ~/.local/state/up
date +%s > ~/.local/state/up/last_upped_at

print_summary
summary_rc=$?

if [ "$summary_rc" -gt 0 ]; then
    print_warn "System update completed with ${summary_rc} failed step(s) — see summary above."
else
    print_msg "System update completed."
fi

exit "$summary_rc"
