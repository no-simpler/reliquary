#!/bin/bash

# Path to the actual yadm executable.
# This wrapper is itself on PATH as `yadm` (a ~/.config/bin/yadm symlink, placed
# ahead of Homebrew by env.d/040-env.sh), so a plain `type -p yadm` would resolve
# back to us and recurse. Scan PATH for the first real yadm OUTSIDE ~/.config/bin.
YADM_BIN=""
_self_dir="$HOME/.config/bin"
_oldifs=$IFS
IFS=:
for _d in $PATH; do
    if [ "$_d" != "$_self_dir" ] && [ -x "$_d/yadm" ]; then
        YADM_BIN="$_d/yadm"
        break
    fi
done
IFS=$_oldifs
unset _self_dir _oldifs _d

if [ -z "$YADM_BIN" ]; then
    echo "yadm-wrapper: real yadm not found on PATH (outside ~/.config/bin)." >&2
    exit 1
fi

# SSH URL of dotfiles repository
REPO_URL_SSH=git@github.com:no-simpler/reliquary.git
REPO_URL_HTTPS=https://github.com/no-simpler/reliquary.git

# Function to get the sha256 of the yadm archive file and store it in a file
store_sha256() {
    ARCHIVE_FILE="$HOME/.local/share/yadm/archive"
    SHA256_FILE="$HOME/.local/state/yadm/last_decrypted"

    if [[ -f $ARCHIVE_FILE ]]; then
        mkdir -p "$(dirname "$SHA256_FILE")"
        shasum -a 256 "$ARCHIVE_FILE" | awk '{print $1}' > "$SHA256_FILE"
        echo "SHA256 of the yadm archive stored in $SHA256_FILE"
    else
        echo "Archive file not found. Skipping SHA256 storage."
    fi
}

# Function to check YADM encrypted files
check_yadm_encrypted_files() {
    local BOLD="\033[1m"
    local NORMAL="\033[0m"
    local YELLOW="\033[33m"
    local RED="\033[31m"
    local last_decrypted_file="$HOME/.local/state/yadm/last_decrypted"
    local yadm_archive="$HOME/.local/share/yadm/archive"

    # Check if the .last_yadm_decrypted file exists
    if [[ ! -f "$last_decrypted_file" ]]; then
        echo -e "${BOLD}==>${NORMAL} ${BOLD}${YELLOW}File ${last_decrypted_file} not found. Consider running yadm decrypt or yadm encrypt.${NORMAL}"
        return
    fi

    # Read the first line of the .last_yadm_decrypted file
    local last_decrypted_sha
    last_decrypted_sha=$(head -n 1 "$last_decrypted_file")

    # Check if the first line looks like a SHA256 hash
    if [[ ! "$last_decrypted_sha" =~ ^[a-fA-F0-9]{64}$ ]]; then
        echo -e "${BOLD}==>${NORMAL} ${BOLD}${RED}Invalid SHA256 hash in ${last_decrypted_file}. Consider running yadm decrypt or yadm encrypt.${NORMAL}"
        return
    fi

    # Check if the yadm archive file exists
    if [[ ! -f "$yadm_archive" ]]; then
        echo -e "${BOLD}==>${NORMAL} ${BOLD}${RED}File ${yadm_archive} not found. Consider running yadm decrypt or yadm encrypt.${NORMAL}"
        return
    fi

    # Calculate the SHA256 of the yadm archive file using shasum
    local current_archive_sha
    current_archive_sha=$(shasum -a 256 "$yadm_archive" | awk '{ print $1 }')

    # Compare the SHA256 hashes
    if [[ "$last_decrypted_sha" != "$current_archive_sha" ]]; then
        echo -e "${BOLD}==>${NORMAL} ${BOLD}${YELLOW}The SHA256 hash of ${yadm_archive} does not match the recorded SHA256 hash. Consider running yadm decrypt or yadm encrypt.${NORMAL}"
    fi
}

# Function to verify encrypted archive contents against disk
verify_encrypted() {
    local archive="$HOME/.local/share/yadm/archive"
    local encrypt_file="$HOME/.config/yadm/encrypt"

    if [[ ! -f "$archive" ]]; then
        echo "Archive not found: $archive"
        return 1
    fi

    if [[ ! -f "$encrypt_file" ]]; then
        echo "Encrypt pattern file not found: $encrypt_file"
        return 1
    fi

    # Create temp dir with automatic cleanup
    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" RETURN

    # Decrypt archive to temp dir (use yadm's configured gpg-program if set)
    local gpg_prog
    gpg_prog="$($YADM_BIN config yadm.gpg-program)"
    gpg_prog="${gpg_prog:-gpg}"

    if ! "$gpg_prog" -d "$archive" 2>/dev/null | tar xf - -C "$tmpdir"; then
        echo "Failed to decrypt archive."
        return 1
    fi

    local has_diff=false

    # Check each file in the archive against disk
    while IFS= read -r -d '' archived_file; do
        local rel_path="${archived_file#$tmpdir/}"
        local disk_path="$HOME/$rel_path"

        if [[ ! -e "$disk_path" ]]; then
            echo "MISSING on disk: ~/$rel_path (exists in archive)"
            has_diff=true
        elif ! diff -q "$archived_file" "$disk_path" &>/dev/null; then
            echo "DIFFERS: ~/$rel_path"
            diff --color=auto -- "$archived_file" "$disk_path" | sed 's|^--- .*|--- archive|;s|^+++ .*|+++ disk|'
            echo
            has_diff=true
        fi
    done < <(find "$tmpdir" -type f -print0 | sort -z)

    # Check encrypt patterns for files on disk not in archive
    while IFS= read -r pattern; do
        [[ -z "$pattern" || "$pattern" == \#* ]] && continue
        local matches
        matches=$(cd "$HOME" && echo $pattern)
        for match in $matches; do
            [[ -e "$HOME/$match" ]] || continue
            [[ -f "$HOME/$match" ]] || continue
            if [[ ! -e "$tmpdir/$match" ]]; then
                echo "MISSING in archive: ~/$match (exists on disk, matched by encrypt pattern)"
                has_diff=true
            fi
        done
    done < "$encrypt_file"

    # Cleanup happens via trap, confirm it
    rm -rf "$tmpdir"
    trap - RETURN
    echo "Temporary decrypted files removed."

    if $has_diff; then
        return 1
    else
        echo "All encrypted files are in sync."
    fi
}

# Function to list the complete tracked set (plaintext + encrypted archive)
list_all_tracked() {
    local BOLD="\033[1m"
    local NORMAL="\033[0m"
    local DIM="\033[2m"

    echo -e "${BOLD}==>${NORMAL} ${BOLD}Plaintext-tracked${NORMAL} ${DIM}(yadm ls-files)${NORMAL}"
    $YADM_BIN ls-files

    echo
    echo -e "${BOLD}==>${NORMAL} ${BOLD}Encrypted-tracked${NORMAL} ${DIM}(archive listing — Touch ID)${NORMAL}"
    $YADM_BIN decrypt -l
}

# Reliquary health self-check helpers
_doctor_ok()   { printf '  \033[32m✓\033[0m %s\n' "$1"; }
_doctor_warn() { printf '  \033[33m!\033[0m %s\n' "$1"; DOCTOR_WARNS=$((DOCTOR_WARNS + 1)); }
_doctor_fail() { printf '  \033[31m✗\033[0m %s\n' "$1"; DOCTOR_FAILS=$((DOCTOR_FAILS + 1)); }
_doctor_skip() { printf '  \033[2m–\033[0m %s\n' "$1"; }
_doctor_head() { printf '\n\033[1m==>\033[0m \033[1m%s\033[0m\n' "$1"; }

# Function: dotfiles/Reliquary health self-check (the actual check sequence).
# Detect-only and Touch-ID-free by default; --full adds the archive verify.
# Wrapped by doctor() below, which adds --quiet on top.
_doctor_run() {
    local full=false
    case "${1:-}" in
        -f|--full) full=true ;;
        "")        ;;
        *) echo "Usage: yadm doctor [--full]" >&2; return 2 ;;
    esac

    DOCTOR_FAILS=0
    DOCTOR_WARNS=0
    local shells="bash zsh fish"

    # Probe each shell ONCE (interactive, so env.d + interactive.d run), tagging
    # each datum so startup noise can't be mistaken for our output.
    local sh probe
    local p_bash p_zsh p_fish
    for sh in $shells; do
        if ! command -v "$sh" >/dev/null 2>&1; then
            eval "p_$sh=__skip__"
            continue
        fi
        if [ "$sh" = fish ]; then
            probe=$("$sh" -ic 'command -v yadm | sed "s/^/__D_YADM__/"; echo __D_OK__; printf "__D_PATH__%s\n" (string join : -- $PATH)' 2>/dev/null)
        else
            probe=$("$sh" -ic 'command -v yadm | sed "s/^/__D_YADM__/"; echo __D_OK__; printf "__D_PATH__%s\n" "$PATH"' 2>/dev/null)
        fi
        eval "p_$sh=\$probe"
    done

    _doctor_get() { # $1=shell var contents, $2=tag -> strips tag prefix, first hit
        printf '%s\n' "$1" | grep "^$2" | head -n1 | sed "s/^$2//"
    }

    # 1. yadm resolves to the wrapper in every shell
    _doctor_head "yadm resolves to the wrapper (not brew)"
    for sh in $shells; do
        eval "probe=\$p_$sh"
        if [ "$probe" = __skip__ ]; then _doctor_skip "$sh not installed"; continue; fi
        local resolved
        resolved=$(_doctor_get "$probe" __D_YADM__)
        if [ "$resolved" = "$HOME/.config/bin/yadm" ]; then
            _doctor_ok "$sh → ~/.config/bin/yadm"
        else
            _doctor_fail "$sh → ${resolved:-(unresolved)} — expected ~/.config/bin/yadm"
        fi
    done

    # 2. Interactive startup smoke test
    _doctor_head "interactive shell startup is clean"
    for sh in $shells; do
        eval "probe=\$p_$sh"
        if [ "$probe" = __skip__ ]; then _doctor_skip "$sh not installed"; continue; fi
        if printf '%s' "$probe" | grep -q __D_OK__; then
            _doctor_ok "$sh -ic starts without error"
        else
            _doctor_fail "$sh -ic did not complete startup"
        fi
    done

    # 3. $PATH free of duplicate entries
    _doctor_head "\$PATH has no duplicate entries"
    for sh in $shells; do
        eval "probe=\$p_$sh"
        if [ "$probe" = __skip__ ]; then _doctor_skip "$sh not installed"; continue; fi
        local path dups
        path=$(_doctor_get "$probe" __D_PATH__)
        dups=$(printf '%s' "$path" | tr ':' '\n' | grep -v '^$' | sort | uniq -d | tr '\n' ' ')
        if [ -z "${dups// /}" ]; then
            _doctor_ok "$sh PATH clean"
        else
            _doctor_warn "$sh PATH duplicates: $dups"
        fi
    done

    unset -f _doctor_get

    # 4. Shell alias/abbr/function parity
    _doctor_head "shell alias/function parity"
    local parity="$HOME/.config/bin/check-shell-parity"
    if [ -x "$parity" ]; then
        local pout prc
        pout=$("$parity" 2>&1); prc=$?
        if [ "$prc" -eq 0 ]; then
            _doctor_ok "in sync across paired configs"
        else
            _doctor_fail "drift detected:"
            printf '%s\n' "$pout" | sed 's/^/      /'
        fi
    else
        _doctor_warn "check-shell-parity not found — skipped"
    fi

    # 5. Bedrock dependencies (present, configured, PATH-accessible)
    _doctor_head "bedrock dependencies"
    local bedrock="$HOME/.config/bin/check-bedrock"
    if [ -x "$bedrock" ]; then
        local bout brc
        bout=$("$bedrock" 2>&1); brc=$?
        if [ "$brc" -eq 0 ]; then
            _doctor_ok "all members present, configured, PATH-accessible"
        elif [ "$brc" -eq 1 ]; then
            _doctor_warn "satisfied with soft issues:"
            printf '%s\n' "$bout" | sed 's/^/      /'
        else
            _doctor_fail "incomplete:"
            printf '%s\n' "$bout" | sed 's/^/      /'
        fi
    else
        _doctor_warn "check-bedrock not found — skipped"
    fi

    # 6. Encrypted-archive drift (SHA compare; no Touch ID)
    _doctor_head "encrypted archive drift"
    local drift
    drift=$(check_yadm_encrypted_files 2>&1)
    if [ -z "$drift" ]; then
        _doctor_ok "archive matches last decrypt/encrypt"
    else
        _doctor_warn "drift — encrypt/decrypt may be needed:"
        printf '%s\n' "$drift" | sed 's/^/      /'
    fi

    # 7. Archive vs disk verification (Touch ID) — opt-in
    _doctor_head "archive vs disk verification"
    if $full; then
        local vout vrc
        vout=$(verify_encrypted 2>&1); vrc=$?
        if [ "$vrc" -eq 0 ]; then
            _doctor_ok "all encrypted files in sync"
        else
            _doctor_fail "differences found:"
            printf '%s\n' "$vout" | sed 's/^/      /'
        fi
    else
        _doctor_skip "skipped — run 'yadm doctor --full' for the Touch-ID deep check"
    fi

    # Summary
    if [ "$DOCTOR_FAILS" -eq 0 ] && [ "$DOCTOR_WARNS" -eq 0 ]; then
        printf '\n\033[1;32m==> healthy\033[0m — all checks passed\n'
    elif [ "$DOCTOR_FAILS" -eq 0 ]; then
        printf '\n\033[1;33m==> ok with %d warning(s)\033[0m\n' "$DOCTOR_WARNS"
    else
        printf '\n\033[1;31m==> %d failure(s), %d warning(s)\033[0m\n' "$DOCTOR_FAILS" "$DOCTOR_WARNS"
    fi
    [ "$DOCTOR_FAILS" -eq 0 ]
}

# Function: doctor entry point. Adds --quiet on top of _doctor_run.
#   (no flags)         full report, exit non-zero only on a failure
#   --full             also run the Touch-ID archive verify
#   --quiet / -q       run silently; print the full report ONLY if not perfectly
#                      healthy (any failure or warning). Used by `yadm update` so
#                      a routine sync stays quiet but a regression still surfaces.
# Flags compose: `yadm doctor --full --quiet` is valid.
doctor() {
    local quiet=false full="" a
    for a in "$@"; do
        case "$a" in
            -q|--quiet) quiet=true ;;
            -f|--full)  full=--full ;;
            *) echo "Usage: yadm doctor [--full] [--quiet]" >&2; return 2 ;;
        esac
    done

    if ! $quiet; then
        _doctor_run $full
        return $?
    fi

    # Quiet: capture the report, emit it only when something needs attention.
    # _doctor_run exits non-zero on failures; warnings keep exit 0, so also gate
    # on the "healthy" summary marker (the only summary that means all-clear).
    local out rc
    out=$(_doctor_run $full 2>&1); rc=$?
    if [ "$rc" -ne 0 ] || ! printf '%s' "$out" | grep -q '==> healthy'; then
        printf '%s\n' "$out"
    fi
    return $rc
}

# Function to set the yadm repo URL
set_yadm_repo_url() {
    local url="$1"
    echo "Setting the yadm repo origin URL to: $url"
    $YADM_BIN remote set-url origin "$url"
}

# Function to handle encrypt/decrypt operations
handle_encrypt_decrypt() {
    local command="$1"
    $YADM_BIN "$command"
    if [[ $? -eq 0 ]]; then
        store_sha256
    else
        echo "Command ${command} failed. SHA256 not stored."
    fi
}

# Function to update yadm repository
update_yadm_repo() {
    $YADM_BIN pull --ff-only || return $?
    # Quiet health check after a deliberate sync: silent when healthy, full
    # report on any drift/regression the pull may have introduced. This already
    # includes the encrypted-archive drift check, so no separate call is needed.
    doctor --quiet
}

# Main script logic
case $1 in
    own)
        set_yadm_repo_url "$REPO_URL_SSH"
        ;;
    disown)
        set_yadm_repo_url "$REPO_URL_HTTPS"
        ;;
    decrypt)
        if [[ ! " ${@:2} " =~ " -l " ]]; then
            handle_encrypt_decrypt "$1"
        else
            $YADM_BIN "$@"
        fi
        ;;
    encrypt)
        handle_encrypt_decrypt "$1"
        ;;
    check)
        check_yadm_encrypted_files
        ;;
    verify)
        verify_encrypted
        ;;
    ls-all)
        list_all_tracked
        ;;
    doctor)
        doctor "${@:2}"
        ;;
    update)
        update_yadm_repo
        ;;
    *)
        $YADM_BIN "$@"
        check_yadm_encrypted_files
        ;;
esac
