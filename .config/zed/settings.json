// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
  },
  "project_panel": {
    "dock": "right",
  },
  "vim_mode": false,
  "theme": "One Light",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "terminal": { "font_size": 14 },
  "format_on_save": "off",
  "autosave": "on_focus_change",
  "auto_update": true,
}
